--- .gitignore (原始)
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
*.class
*.dll
*.so
*.a
*.out

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
*.env.*

# Logs and temp files
*.log
*.tmp
*.swp

# Editors
.vscode/
.idea/

# Build directories
dist/
build/
target/
.gradle/

# Coverage
coverage/
htmlcov/
.coverage

# Python cache
.mypy_cache/
.pytest_cache/

