# Firebase Configuration (Web)
FIREBASE_API_KEY_WEB=your_api_key_here
FIREBASE_APP_ID_WEB=your_app_id_here
FIREBASE_MESSAGING_SENDER_ID=your_messaging_id_here
FIREBASE_PROJECT_ID=your_project_id_here
FIREBASE_AUTH_DOMAIN=your_auth_domain_here
FIREBASE_STORAGE_BUCKET=your_storage_bucket_here
FIREBASE_MEASUREMENT_ID=your_measurement_id_here

# Firebase Configuration (Android)
FIREBASE_API_KEY_ANDROID=your_api_key_here
FIREBASE_APP_ID_ANDROID=your_app_id_here

# Firebase Configuration (iOS/macOS)
FIREBASE_API_KEY_IOS=your_api_key_here
FIREBASE_APP_ID_IOS=your_app_id_here
FIREBASE_IOS_BUNDLE_ID=com.example.glassKeepApp

# Firebase Configuration (Windows)
FIREBASE_API_KEY_WINDOWS=your_api_key_here
FIREBASE_APP_ID_WINDOWS=your_app_id_here

# Environment
ENVIRONMENT=development
